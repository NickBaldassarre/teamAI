# Recommended MLX model for an M1 Pro / 16GB machine.
TEAMAI_MODEL_ID=mlx-community/gemma-4-e4b-it-4bit

# Optional: set a Hugging Face token for higher download rate limits.
# HF_TOKEN=

# Optional model loading controls.
TEAMAI_MODEL_REVISION=
TEAMAI_FORCE_DOWNLOAD=false
TEAMAI_TRUST_REMOTE_CODE=false
TEAMAI_ENABLE_THINKING=false

# Local runtime defaults.
TEAMAI_WORKSPACE_ROOT=.
TEAMAI_MAX_ROUNDS=4
TEAMAI_MAX_ACTIONS_PER_ROUND=3
TEAMAI_MAX_TOKENS_PER_TURN=320
TEAMAI_TEMPERATURE=0.3

# Tool safety settings.
TEAMAI_ALLOW_SHELL=true
TEAMAI_ALLOW_WRITES=false
TEAMAI_COMMAND_TIMEOUT_SECONDS=30
TEAMAI_MAX_FILE_BYTES=50000
TEAMAI_MAX_COMMAND_OUTPUT_CHARS=12000

# teamAI persists local state in `.teamai/` inside the workspace:
# - run-history.jsonl
# - memory.md

# FastAPI service defaults.
TEAMAI_HOST=127.0.0.1
TEAMAI_PORT=8000
